{
   "action": {
      "default_icon": {
         "128": "icon128.png",
         "16": "icon16.png",
         "48": "icon48.png"
      },
      "default_title": "Download YouTube Subtitles (Right-click for format & language options)"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "https://*.youtube.com/*" ],
      "run_at": "document_end"
   } ],
   "description": "Download YouTube subtitles in any language - SRT, TXT, or copy to clipboard. 70+ languages supported.",
   "host_permissions": [ "https://*.youtube.com/*" ],
   "icons": {
      "128": "icon128.png",
      "16": "icon16.png",
      "48": "icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "YouTube Subtitle Downloader",
   "permissions": [ "storage", "webRequest", "contextMenus", "clipboardWrite" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.3.0"
}
