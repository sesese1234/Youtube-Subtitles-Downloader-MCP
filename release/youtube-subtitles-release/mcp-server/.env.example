# Environment variables for the YouTube Subtitles MCP Server
# Copy this to .env and adjust as needed

# HTTP Bridge port (default: 3847)
BRIDGE_PORT=3847

# HTTP Bridge host (default: 127.0.0.1 — localhost only)
BRIDGE_HOST=127.0.0.1

# Rate limiting: max requests per window (default: 30)
RATE_LIMIT_MAX=30

# Rate limiting: window duration in ms (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
